    "/* Create a new table called persons with columns:\n",
    "id, person_name, birth_date, and phone*/\n",
    "CREATE TABLE persons (\n",
    "    id INT NOT NULL,\n",
    "    person_name VARCHAR(50) NOT NULL,\n",
    "    birth_date DATE,\n",
    "    phone VARCHAR(50) NOT NULL,\n",
    "    CONSTRAINT persons_pk PRIMARY KEY (id)\n",
    ")"
